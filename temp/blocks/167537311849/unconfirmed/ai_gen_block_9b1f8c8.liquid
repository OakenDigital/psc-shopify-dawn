{% doc %}
  @prompt
    In the cart page, display the variant SKU for each line item directly below the price, under the product title. The SKU should only show if the variant has a SKU assigned. Style it to be subtle (small, muted text) and consistent with the existing cart line item layout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cart-sku-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-cart-sku-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.spacing_top }}px;
  }

  .ai-cart-sku-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    opacity: {{ block.settings.text_opacity | divided_by: 100.0 }};
    line-height: 1.4;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-cart-sku-label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.9);
    }
  }
{% endstyle %}

<cart-line-sku-{{ ai_gen_id }} class="ai-cart-sku-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% for item in cart.items %}
    {% if item.variant.sku != blank %}
      <div class="ai-cart-sku-wrapper-{{ ai_gen_id }}" data-line-item-key="{{ item.key }}">
        <p class="ai-cart-sku-label-{{ ai_gen_id }}">
          {% if block.settings.show_label %}{{ block.settings.label_text }}: {% endif %}{{ item.variant.sku }}
        </p>
      </div>
    {% endif %}
  {% endfor %}
</cart-line-sku-{{ ai_gen_id }}>

<script>
  (function() {
    class CartLineSku{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.attachToCartItems();
        this.observeCartChanges();
      }

      attachToCartItems() {
        const skuWrappers = this.querySelectorAll('.ai-cart-sku-wrapper-{{ ai_gen_id }}');
        
        skuWrappers.forEach((wrapper) => {
          const lineItemKey = wrapper.getAttribute('data-line-item-key');
          const cartItem = document.querySelector(`[data-key="${lineItemKey}"]`);
          
          if (cartItem) {
            const priceElement = cartItem.querySelector('.cart-item__price-wrapper, .price, [class*="price"]');
            
            if (priceElement) {
              const skuClone = wrapper.cloneNode(true);
              priceElement.parentNode.insertBefore(skuClone, priceElement.nextSibling);
            }
          }
        });

        this.style.display = 'none';
      }

      observeCartChanges() {
        const cartElement = document.querySelector('cart-items, [data-cart-items]');
        
        if (cartElement) {
          const observer = new MutationObserver(() => {
            this.attachToCartItems();
          });

          observer.observe(cartElement, {
            childList: true,
            subtree: true
          });
        }
      }
    }

    customElements.define('cart-line-sku-{{ ai_gen_id }}', CartLineSku{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Cart line SKU",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "Show label",
      "default": true
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Label text",
      "default": "SKU"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#6b7280"
    },
    {
      "type": "range",
      "id": "text_opacity",
      "label": "Text opacity",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 70
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Spacing above",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Cart line SKU"
    }
  ]
}
{% endschema %}
