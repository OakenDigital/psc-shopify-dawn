      "id": "max_images",
      "label": "Maximum images",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 12
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
