          "label": "Landscape (4:3)"
        },
        {
          "value": "3 / 4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "16 / 9",
          "label": "Wide (16:9)"
        }
      ],
      "default": "1 / 1"
    },
    {
      "type": "range",
