{% doc %}
  @prompt
    create a responsive image grid that will display the images from my connected yotpo app
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-yotpo-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-yotpo-grid__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-yotpo-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-yotpo-grid__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-yotpo-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-yotpo-grid__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.placeholder_bg_color }};
    aspect-ratio: {{ block.settings.aspect_ratio }};
  }

  .ai-yotpo-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  {% if block.settings.enable_hover_zoom %}
    .ai-yotpo-grid__item-{{ ai_gen_id }}:hover .ai-yotpo-grid__image-{{ ai_gen_id }} {
      transform: scale(1.05);
    }
  {% endif %}

  .ai-yotpo-grid__overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}), transparent);
    padding: 16px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  {% if block.settings.show_overlay %}
    .ai-yotpo-grid__item-{{ ai_gen_id }}:hover .ai-yotpo-grid__overlay-{{ ai_gen_id }} {
      opacity: 1;
    }
  {% endif %}

  .ai-yotpo-grid__overlay-text-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 14px;
    margin: 0;
  }

  .ai-yotpo-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-yotpo-grid__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-yotpo-grid__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    max-width: 80%;
  }

  @media screen and (max-width: 989px) {
    .ai-yotpo-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ai-yotpo-grid__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }

    .ai-yotpo-grid__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-yotpo-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-yotpo-grid-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<yotpo-image-grid-{{ ai_gen_id }} class="ai-yotpo-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-yotpo-grid__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-yotpo-grid__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-yotpo-grid__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-yotpo-grid__container-{{ ai_gen_id }}" data-yotpo-container>
    {% for i in (1..12) %}
      <div class="ai-yotpo-grid__item-{{ ai_gen_id }}">
        <div class="ai-yotpo-grid__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          {% if forloop.first %}
            <div class="ai-yotpo-grid__empty-state-{{ ai_gen_id }}">
              Connect your Yotpo app to display UGC images
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</yotpo-image-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class YotpoImageGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.container = this.querySelector('[data-yotpo-container]');
      }

      connectedCallback() {
        this.loadYotpoImages();
        this.setupYotpoListener();
      }

      setupYotpoListener() {
        if (window.yotpo && window.yotpo.initialized) {
          this.loadYotpoImages();
        } else {
          document.addEventListener('yotpo:ready', () => {
            this.loadYotpoImages();
          });
        }
      }

      loadYotpoImages() {
        if (typeof window.yotpo === 'undefined' || !window.yotpo.widgets) {
          console.warn('Yotpo is not loaded yet');
          return;
        }

        const yotpoData = this.getYotpoData();
        if (yotpoData && yotpoData.length > 0) {
          this.renderImages(yotpoData);
        }
      }

      getYotpoData() {
        if (window.yotpoWidgetsData && window.yotpoWidgetsData.reviews) {
          const reviews = window.yotpoWidgetsData.reviews;
          return reviews
            .filter(review => review.images && review.images.length > 0)
            .flatMap(review => 
              review.images.map(image => ({
                url: image.original_url || image.thumb_url,
                alt: review.title || 'Customer photo',
                reviewer: review.user ? review.user.display_name : 'Customer',
                rating: review.score
              }))
            )
            .slice(0, {{ block.settings.max_images }});
        }
        return [];
      }

      renderImages(images) {
        const items = this.container.querySelectorAll('.ai-yotpo-grid__item-{{ ai_gen_id }}');
        
        images.forEach((imageData, index) => {
          if (index < items.length) {
            const item = items[index];
            item.innerHTML = `
              <img 
                src="${imageData.url}" 
                alt="${imageData.alt}"
                class="ai-yotpo-grid__image-{{ ai_gen_id }}"
                loading="lazy"
              >
              {% if block.settings.show_overlay %}
                <div class="ai-yotpo-grid__overlay-{{ ai_gen_id }}">
                  <p class="ai-yotpo-grid__overlay-text-{{ ai_gen_id }}">
                    ${imageData.reviewer}
                    ${imageData.rating ? ' • ' + '★'.repeat(imageData.rating) : ''}
                  </p>
                </div>
              {% endif %}
            `;
          }
        });

        for (let i = images.length; i < items.length; i++) {
          items[i].style.display = 'none';
        }
      }
    }

    customElements.define('yotpo-image-grid-{{ ai_gen_id }}', YotpoImageGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Yotpo image grid",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Customer photos"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "See how our customers use our products"
    },
    {
