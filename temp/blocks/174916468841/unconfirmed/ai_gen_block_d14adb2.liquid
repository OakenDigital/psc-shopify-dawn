{% doc %}
  @prompt
    a responsive image grid that will display photos in order recived, reduce the image to thumbnail size 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-image-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-image-grid__item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.thumbnail_size }}px;
    overflow: hidden;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-image-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: {{ block.settings.aspect_ratio }};
  }

  .ai-image-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-image-grid__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media screen and (max-width: 749px) {
    .ai-image-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<image-grid-{{ ai_gen_id }} class="ai-image-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-grid__container-{{ ai_gen_id }}">
    {% for i in (1..12) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign image = block.settings[image_key]
      %}
      
      {% if image != blank %}
        <div class="ai-image-grid__item-{{ ai_gen_id }}">
          <img
            src="{{ image | image_url: width: 400 }}"
            alt="{{ image.alt | escape }}"
            loading="lazy"
            width="{{ image.width }}"
            height="{{ image.height }}"
            class="ai-image-grid__image-{{ ai_gen_id }}"
          >
        </div>
      {% endif %}
    {% endfor %}

    {% if block.settings.image_1 == blank and block.settings.image_2 == blank and block.settings.image_3 == blank and block.settings.image_4 == blank and block.settings.image_5 == blank and block.settings.image_6 == blank and block.settings.image_7 == blank and block.settings.image_8 == blank and block.settings.image_9 == blank and block.settings.image_10 == blank and block.settings.image_11 == blank and block.settings.image_12 == blank %}
      {% for i in (1..6) %}
        <div class="ai-image-grid__item-{{ ai_gen_id }}">
          <div class="ai-image-grid__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</image-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('image-grid-{{ ai_gen_id }}', ImageGrid{{ ai_gen_id }});
  })();
</script>

