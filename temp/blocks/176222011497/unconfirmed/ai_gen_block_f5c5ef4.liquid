{% doc %}
  @prompt
    Add swatch hover functionality to product cards in collection pages so that when a color swatch is hovered, the product thumbnail image changes to show that variant's image. The swatches should be displayed below the product title/price on each product card, and hovering a swatch should swap the main product card image to the corresponding variant image. When the hover ends, the image should revert to the default product image.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-card-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-product-card-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    height: 100%;
  }

  .ai-product-card-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.3s ease;
  }

  .ai-product-card-image-{{ ai_gen_id }}.ai-hidden-{{ ai_gen_id }} {
    opacity: 0;
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-card-vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_font_size }}px;
    color: {{ block.settings.vendor_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-product-card-title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-product-card-title-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .ai-product-card-price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
  }

  .ai-product-card-price-sale-{{ ai_gen_id }} {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-product-card-swatches-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .ai-product-card-swatch-{{ ai_gen_id }} {
    width: {{ block.settings.swatch_size }}px;
    height: {{ block.settings.swatch_size }}px;
    border-radius: {{ block.settings.swatch_shape }};
    border: 2px solid {{ block.settings.swatch_border_color }};
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease;
    position: relative;
  }

  .ai-product-card-swatch-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
    border-color: {{ block.settings.swatch_hover_border_color }};
  }

  .ai-product-card-swatch-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.swatch_hover_border_color }};
    outline-offset: 2px;
  }

  .ai-product-card-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-product-card-badge-sale-{{ ai_gen_id }} {
    background-color: {{ block.settings.sale_badge_bg_color }};
    color: {{ block.settings.sale_badge_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-card-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<product-card-{{ ai_gen_id }}
  class="ai-product-card-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.product %}
    {% assign product = block.settings.product %}
    
    <div class="ai-product-card-wrapper-{{ ai_gen_id }}">
      <div class="ai-product-card-image-container-{{ ai_gen_id }}">
        <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.featured_image.alt | escape }}"
              loading="lazy"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
              class="ai-product-card-image-{{ ai_gen_id }} ai-product-card-default-image-{{ ai_gen_id }}"
              data-default-image
            >
          {% else %}
            <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% for variant in product.variants %}
            {% if variant.featured_image and variant.featured_image.id != product.featured_image.id %}
              <img
                src="{{ variant.featured_image | image_url: width: 800 }}"
                alt="{{ variant.featured_image.alt | escape }}"
                loading="lazy"
                width="{{ variant.featured_image.width }}"
                height="{{ variant.featured_image.height }}"
                class="ai-product-card-image-{{ ai_gen_id }} ai-hidden-{{ ai_gen_id }}"
                data-variant-id="{{ variant.id }}"
              >
            {% endif %}
          {% endfor %}
        </a>

        {% if product.available == false %}
          <div class="ai-product-card-badge-{{ ai_gen_id }}">
            {{ block.settings.sold_out_text }}
          </div>
        {% elsif product.compare_at_price > product.price %}
          <div class="ai-product-card-badge-{{ ai_gen_id }} ai-product-card-badge-sale-{{ ai_gen_id }}">
            {{ block.settings.sale_text }}
          </div>
        {% endif %}
      </div>

      <div class="ai-product-card-info-{{ ai_gen_id }}">
        {% if block.settings.show_vendor and product.vendor != blank %}
          <div class="ai-product-card-vendor-{{ ai_gen_id }}">
            {{ product.vendor }}
          </div>
        {% endif %}

        <h3 class="ai-product-card-title-{{ ai_gen_id }}">
          <a href="{{ product.url }}" class="ai-product-card-title-link-{{ ai_gen_id }}">
            {{ product.title }}
          </a>
        </h3>

        <div class="ai-product-card-price-{{ ai_gen_id }}">
          {% if product.compare_at_price > product.price %}
            <span class="ai-product-card-price-compare-{{ ai_gen_id }}">
              {{ product.compare_at_price | money }}
            </span>
            <span class="ai-product-card-price-sale-{{ ai_gen_id }}">
              {{ product.price | money }}
            </span>
          {% else %}
            <span>{{ product.price | money }}</span>
          {% endif %}
        </div>

        {% if block.settings.show_swatches %}
          {% assign color_option_index = nil %}
          {% for option in product.options_with_values %}
            {% assign option_name_downcase = option.name | downcase %}
            {% if option_name_downcase == 'color' or option_name_downcase == 'colour' %}
              {% assign color_option_index = forloop.index0 %}
              {% break %}
            {% endif %}
          {% endfor %}

          {% if color_option_index != nil %}
            <div class="ai-product-card-swatches-{{ ai_gen_id }}">
              {% assign displayed_colors = '' %}
              {% for variant in product.variants %}
                {% assign color_value = variant.options[color_option_index] %}
                {% unless displayed_colors contains color_value %}
                  {% assign displayed_colors = displayed_colors | append: color_value | append: ',' %}
                  
                  {% assign swatch_color = color_value | downcase | replace: ' ', '-' %}
                  
                  <button
                    type="button"
                    class="ai-product-card-swatch-{{ ai_gen_id }}"
                    style="background-color: {{ color_value | downcase | replace: ' ', '' }};"
                    data-variant-id="{{ variant.id }}"
                    aria-label="{{ color_value }}"
                    title="{{ color_value }}"
                  ></button>
                {% endunless %}
              {% endfor %}
            </div>
          {% endif %}
        {% endif %}
      </div>
    </div>
  {% else %}
    <div class="ai-product-card-wrapper-{{ ai_gen_id }}">
      <div class="ai-product-card-image-container-{{ ai_gen_id }}">
        <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      </div>
      <div class="ai-product-card-info-{{ ai_gen_id }}">
        <h3 class="ai-product-card-title-{{ ai_gen_id }}">Product title</h3>
        <div class="ai-product-card-price-{{ ai_gen_id }}">$0.00</div>
      </div>
    </div>
  {% endif %}
</product-card-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.swatches = this.querySelectorAll('.ai-product-card-swatch-{{ ai_gen_id }}');
        this.images = this.querySelectorAll('.ai-product-card-image-{{ ai_gen_id }}');
        this.defaultImage = this.querySelector('[data-default-image]');
      }

      connectedCallback() {
        this.setupSwatchHover();
      }

      setupSwatchHover() {
        this.swatches.forEach((swatch) => {
          swatch.addEventListener('mouseenter', () => {
            const variantId = swatch.getAttribute('data-variant-id');
            this.showVariantImage(variantId);
          });

          swatch.addEventListener('mouseleave', () => {
            this.resetToDefaultImage();
          });

          swatch.addEventListener('focus', () => {
            const variantId = swatch.getAttribute('data-variant-id');
            this.showVariantImage(variantId);
          });

          swatch.addEventListener('blur', () => {
            this.resetToDefaultImage();
          });
        });
      }

      showVariantImage(variantId) {
        const variantImage = this.querySelector(`[data-variant-id="${variantId}"]`);
        
        if (variantImage && variantImage.tagName === 'IMG') {
          this.images.forEach((img) => {
            img.classList.add('ai-hidden-{{ ai_gen_id }}');
          });
          
          variantImage.classList.remove('ai-hidden-{{ ai_gen_id }}');
        }
      }

      resetToDefaultImage() {
        this.images.forEach((img) => {
          img.classList.add('ai-hidden-{{ ai_gen_id }}');
        });
        
        if (this.defaultImage) {
          this.defaultImage.classList.remove('ai-hidden-{{ ai_gen_id }}');
        }
      }
    }

    customElements.define('product-card-{{ ai_gen_id }}', ProductCard{{ ai_gen_id }});
  })();
</script>

