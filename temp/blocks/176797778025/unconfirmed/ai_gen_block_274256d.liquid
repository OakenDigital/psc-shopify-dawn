{% doc %}
  @prompt
    Create a "PSC Certified Refurbished" product badge that displays on product pages and product cards. The badge should have a rugged, premium automotive feel — dark background (charcoal or black) with bold accent color (gold or orange), include a small checkmark or shield icon, and display the text "PSC Certified Refurbished". It should be a reusable block that can be toggled on specific products using a product tag (e.g., tag = "certified-refurbished"), and should appear prominently near the product title or price on the PDP and optionally on collection cards.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% if product.tags contains block.settings.product_tag %}
  {% style %}
    .ai-refurb-badge-{{ ai_gen_id }} {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      background-color: {{ block.settings.badge_bg_color }};
      border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
      border-radius: {{ block.settings.border_radius }}px;
      font-family: {{ block.settings.badge_font.family }}, {{ block.settings.badge_font.fallback_families }};
      font-weight: {{ block.settings.badge_font.weight }};
      font-size: {{ block.settings.font_size }}px;
      line-height: 1.2;
      text-transform: {{ block.settings.text_transform }};
      letter-spacing: 0.5px;
      color: {{ block.settings.text_color }};
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      width: {{ block.settings.desktop_width_percent }}%;
      max-width: 100%;
      justify-content: center;
    }

    .ai-refurb-badge-icon-{{ ai_gen_id }} {
      flex-shrink: 0;
      width: {{ block.settings.icon_size }}px;
      height: {{ block.settings.icon_size }}px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .ai-refurb-badge-icon-{{ ai_gen_id }} svg {
      width: 100%;
      height: 100%;
      fill: {{ block.settings.icon_color }};
    }

    .ai-refurb-badge-text-{{ ai_gen_id }} {
      font-weight: {{ block.settings.text_weight }};
    }

    @media screen and (max-width: 749px) {
      .ai-refurb-badge-{{ ai_gen_id }} {
        font-size: {{ block.settings.font_size | times: 0.9 }}px;
        padding: 6px 12px;
        gap: 6px;
      }

      .ai-refurb-badge-icon-{{ ai_gen_id }} {
        width: {{ block.settings.icon_size | times: 0.85 }}px;
        height: {{ block.settings.icon_size | times: 0.85 }}px;
      }
    }
  {% endstyle %}

  <div class="ai-refurb-badge-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    {% if block.settings.show_icon %}
      <span class="ai-refurb-badge-icon-{{ ai_gen_id }}">
        {% if block.settings.icon_style == 'shield' %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2L4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3zm-1.06 13.54L7.4 12l1.41-1.41 2.12 2.12 4.24-4.24 1.41 1.41-5.64 5.66z"/>
          </svg>
        {% elsif block.settings.icon_style == 'checkmark' %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
          </svg>
        {% elsif block.settings.icon_style == 'star' %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27z"/>
          </svg>
        {% endif %}
      </span>
    {% endif %}
    <span class="ai-refurb-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_text }}</span>
  </div>
{% endif %}

{% schema %}
{
  "name": "PSC certified refurbished",
  "settings": [
    {
      "type": "header",
      "content": "Badge content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "PSC Certified Refurbished"
    },
    {
      "type": "text",
      "id": "product_tag",
      "label": "Product tag",
      "default": "certified-refurbished",
      "info": "Badge will only display on products with this tag"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon style",
      "options": [
        {
          "value": "shield",
          "label": "Shield with checkmark"
        },
        {
          "value": "checkmark",
          "label": "Checkmark only"
        },
        {
          "value": "star",
          "label": "Star"
        }
      ],
      "default": "shield"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Badge style"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Background color",
      "default": "#2d2926"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#d4a857"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#d4a857"
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "Border thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "badge_font",
      "label": "Font",
      "default": "system_ui_n7"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra bold"
        }
      ],
      "default": "700"
    }
  ],
  "presets": [
    {
      "name": "PSC certified refurbished"
    }
  ]
}
{% endschema %}
