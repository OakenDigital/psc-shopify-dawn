      "settings": {
        "custom_liquid": "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\">\n\n<style>\n.psc-page * { box-sizing:border-box; margin:0; padding:0; }\n\n.psc-page {\n  background:#2D2926;\n  color:#fff;\n}\n\n/* HERO */\n.psc-hero {\n  background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)),\n              url('YOUR_IMAGE_URL_HERE') center/cover no-repeat;\n  padding:80px 20px;\n  text-align:center;\n  border-bottom:4px solid #D6001C;\n}\n\n.psc-hero-title {\n  font-size:clamp(40px,8vw,80px);\n  font-weight:900;\n  text-transform:uppercase;\n}\n\n.psc-hero-title span { color:#D6001C; }\n\n.psc-hero-sub {\n  color:rgba(255,255,255,0.8);\n  margin:20px auto;\n  max-width:600px;\n}\n\n.psc-btn {\n  background:#D6001C;\n  color:#fff;\n  padding:14px 28px;\n  font-weight:700;\n  text-transform:uppercase;\n  text-decoration:none;\n  display:inline-block;\n}\n\n/* SECTION */\n.psc-section { padding:60px 20px; text-align:center; }\n\n.psc-title {\n  font-size:40px;\n  font-weight:900;\n  margin-bottom:30px;\n}\n\n/* STEPS */\n.psc-steps {\n  display:grid;\n  grid-template-columns:repeat(auto-fit,minmax(200px,1fr));\n  gap:20px;\n  max-width:900px;\n  margin:0 auto;\n}\n\n.psc-step {\n  background:rgba(255,255,255,0.05);\n  padding:25px;\n}\n\n.psc-step-num {\n  font-size:50px;\n  font-weight:900;\n  color:#D6001C;\n}\n\n/* GALLERY */\n.psc-gallery { padding:60px 20px; background:#231F1C; }\n\n/* FORM */\n.psc-form { max-width:600px; margin:0 auto; }\n\n.psc-input {\n  width:100%;\n  padding:12px;\n  margin-bottom:12px;\n  background:#333;\n  border:1px solid #555;\n  color:#fff;\n}\n\n/* CTA */\n.psc-submit {\n  width:100%;\n  padding:16px;\n  background:#D6001C;\n  border:none;\n  font-weight:700;\n  color:white;\n  cursor:pointer;\n}\n</style>\n\n<div class=\"psc-page\">\n\n  <!-- HERO -->\n  <div class=\"psc-hero\">\n    <h1 class=\"psc-hero-title\">PSC <span>Pit Crew</span></h1>\n    <p class=\"psc-hero-sub\">\n      You run PSC. That makes you one of us. Show your build and get on the wall.\n    </p>\n    <a href=\"#submit\" class=\"psc-btn\">Submit Your Ride</a>\n  </div>\n\n  <!-- HOW IT WORKS -->\n  <div class=\"psc-section\">\n    <h2 class=\"psc-title\">How It Works</h2>\n\n    <div class=\"psc-steps\">\n      <div class=\"psc-step\">\n        <div class=\"psc-step-num\">1</div>\n        Use PSC on your build\n      </div>\n\n      <div class=\"psc-step\">\n        <div class=\"psc-step-num\">2</div>\n        Tag #PSCPitCrew or submit\n      </div>\n\n      <div class=\"psc-step\">\n        <div class=\"psc-step-num\">3</div>\n        Get featured + win gear\n      </div>\n    </div>\n  </div>\n\n  <!-- GALLERY -->\n  <div class=\"psc-gallery\" id=\"wall\">\n    <h2 class=\"psc-title\">The Wall</h2>\n\n    <div class=\"yotpo-pictures-widget\"\n         data-gallery-id=\"6a074253d3f9ab8582a43b4d\">\n    </div>\n\n    <script async src=\"https://staticw2.yotpo.com/aALPckUeDgYF7UsB1pfThIwLEsiyKc4wVIRZzKOl/widget.js\"></script>\n\n    <p style=\"margin-top:20px;color:#D6001C;font-weight:bold;\">#PSCPitCrew</p>\n  </div>\n\n  <!-- FORM -->\n  <div class=\"psc-section\" id=\"submit\">\n    <h2 class=\"psc-title\">Submit Your Build</h2>\n\n    <form method=\"post\" action=\"/contact\">\n      <input type=\"hidden\" name=\"form_type\" value=\"contact\">\n      <input type=\"hidden\" name=\"contact[tags]\" value=\"PSC Pit Crew\">\n\n      <input class=\"psc-input\" type=\"text\" name=\"contact[first_name]\" placeholder=\"Jason\" required>\n      <input class=\"psc-input\" type=\"text\" name=\"contact[last_name]\" placeholder=\"Walker\" required>\n      <input class=\"psc-input\" type=\"email\" name=\"contact[email]\" placeholder=\"jason@email.com\" required>\n\n      <input class=\"psc-input\" type=\"text\" name=\"contact[vehicle]\" placeholder=\"2019 Ford F-150\">\n\n      <textarea class=\"psc-input\" name=\"contact[body]\" placeholder=\"PSC pump, Cylinder Assist®,